# =============================================================================
# FCDocker Environment Configuration Template
# =============================================================================
# Copy this file to .env and update with your actual values
# Never commit .env to version control!
#
# PLACEHOLDER GUIDE:
# - your-*-here = Replace with your actual sensitive tokens/keys
# - Default values = Safe defaults that work for development
# - Comments show where to get tokens and best practices

# -----------------------------------------------------------------------------
# Database Configuration - Default PostgreSQL settings for development
# -----------------------------------------------------------------------------
POSTGRES_DB=fullcontact
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5433

# -----------------------------------------------------------------------------
# Django Backend Configuration  
# -----------------------------------------------------------------------------
# Generate a secure secret key: https://djecrety.ir/
DJANGO_ALLOWED_HOSTS=*

# -----------------------------------------------------------------------------
# External API Integrations
# -----------------------------------------------------------------------------

# SwaggerHub Configuration
# Get from: https://app.swaggerhub.com/settings/apiKey
SWAGGERHUB_API_TOKEN=your-swaggerhub-token-here
SWAGGERHUB_ORGANIZATION=your-org-name

# PactFlow Configuration  
# Get from: https://yourorg.pactflow.io/settings/tokens
PACTFLOW_BROKER_BASE_URL=https://your-organization.pactflow.io/
# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
NODE_ENV=development

# API URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# CORS Configuration (set to false in production for security)
CORS_ALLOW_ALL=true

# -----------------------------------------------------------------------------
# Development/Testing Configuration
# -----------------------------------------------------------------------------
DEFAULT_PARTICIPANT_VERSION=1.0.0
DEFAULT_ENVIRONMENT=development
DEFAULT_ENVIRONMENT=development