{
  "name": "fcdocker",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["frontend"],
  "scripts": {
    "frontend:dev": "npm run dev --workspace=frontend",
    "frontend:build": "npm run build --workspace=frontend",
    "frontend:test": "npm run test --workspace=frontend",
    "backend:test-contracts": "cd fc && npm run pact:all && npm run drift:all",
    "test:all": "npm run frontend:test && npm run backend:test-contracts",
    "dev:full": "docker-compose up -d && npm run frontend:dev",
    "setup": "npm install && cd fc && pip install -r requirements.txt"
  },
  "devDependencies": {
    "@pactflow/drift": "*",
    "@pact-foundation/pact": "^15.0.1",
    "@pact-foundation/pact-cli": "^16.0.7",
    "jest": "^29.7.0",
    "dotenv": "^16.6.1",
    "axios": "^1.8.3",
    "dotenv-cli": "^8.0.0"
  }
}