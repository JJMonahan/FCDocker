# =============================================================================
# FCDocker PRODUCTION Environment Configuration Template
# =============================================================================
# Copy this file to .env.production for production deployments
# WARNING: Update ALL placeholder values before deploying!
#
# SECURITY NOTICE:
# - All CHANGE_ME_* values MUST be updated with secure credentials
# - Default passwords are NOT suitable for production
# - Review all settings for production security requirements

# -----------------------------------------------------------------------------
# Database Configuration - Production settings with secure credentials
# -----------------------------------------------------------------------------
POSTGRES_DB=fullcontact_prod
POSTGRES_USER=fullcontact_prod_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5433

# -----------------------------------------------------------------------------
# Django Backend Configuration  
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET_KEY_FOR_PRODUCTION
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com

# -----------------------------------------------------------------------------
# External API Integrations
# -----------------------------------------------------------------------------

# SwaggerHub Configuration
# Get from: https://app.swaggerhub.com/settings/apiKey
SWAGGERHUB_API_TOKEN=your_production_swaggerhub_token
SWAGGERHUB_ORGANIZATION=your_org_name

# PactFlow Configuration
# Get from: https://yourorg.pactflow.io/settings/tokens
PACTFLOW_BROKER_TOKEN=your_production_pactflow_token

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_VERSION=1.0.0
APP_ENVIRONMENT=production
NODE_ENV=production

# API URLs (update with your actual production domains)
BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# CORS Configuration (IMPORTANT: Set to false for production security!)
CORS_ALLOW_ALL=false

# -----------------------------------------------------------------------------
# Production/Security Configuration
# -----------------------------------------------------------------------------
DEFAULT_PARTICIPANT_VERSION=1.0.0
DEFAULT_ENVIRONMENT=production

# SSL/TLS Settings
FORCE_SSL=true
SECURE_SSL_REDIRECT=true