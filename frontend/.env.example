# SwaggerHub API Configuration
# Get your token from: https://app.swaggerhub.com/settings/apiKey
SWAGGERHUB_API_TOKEN=your_swaggerhub_token_here
SWAGGERHUB_ORGANIZATION=your_org_name

# PactFlow Configuration for Drift Testing
# Get your token from: https://yourorg.pactflow.io/settings/tokens
PACTFLOW_BROKER_BASE_URL=https://yourorg.pactflow.io/
PACTFLOW_BROKER_TOKEN=your_pactflow_token_here

# Drift Testing Configuration
DEFAULT_PARTICIPANT_VERSION=1.0.0
DEFAULT_ENVIRONMENT=development
# Copy this to .env and update with your actual token

# SwaggerHub API Token (get from SwaggerHub → Settings → API Tokens)  
SWAGGERHUB_API_TOKEN=your-swaggerhub-token-here

# SwaggerHub API Details for Full Contact  
SWAGGERHUB_ORG=Monahan-Tutorials
SWAGGERHUB_API=Full-Contact-Django-extract
SWAGGERHUB_VERSION=1.0.2

# For testing different versions
# SWAGGERHUB_VERSION=latest
# SWAGGERHUB_VERSION=0.1.0