{
  "name": "frontend",
  "version": "1.0.5",
  "scripts": {
    "dev:docker": "vite --host",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix --ignore-path .gitignore",
    "test": "jest --runInBand",
    "debug": "node tests/pact/debug.js",
    "test:pact": "jest tests/pact --runInBand",
    "publish-pacts": "node tests/pact/publish-pacts.js",
    "verify-provider": "node tests/pact/verify-provider.js",
    "publish-provider": "node tests/pact/publish-provider.js",
    "validate-consumer-bidi": "node tests/pact/validate-consumer-bidi.js",
    "verify-bidi": "node tests/pact/verify-bidi-contracts.js",
    "deploy-provider": "node tests/pact/deploy-provider.js",
    "publish-verification": "node tests/pact/publish-verification.js",
    "fake-provider-verification": "node tests/pact/fake-provider-verification.js",
    "verify-consumer-pacts": "node tests/pact/verify-consumer-pacts.js",
    "publish-all": "npm run test:pact && npm run publish-pacts && npm run deploy-provider",
    "drift:help": "npx @pactflow/drift --help",
    "drift:auth": "npx @pactflow/drift auth login", 
    "drift:verify": "npx --yes dotenv-cli -e .env.local -- @pactflow/drift verify --test-files drift.yaml --server-url http://localhost:8000",
    "drift:verify-swaggerhub-only": "npx --yes dotenv-cli -e .env.local -- @pactflow/drift verify --test-files drift.yaml",
    "drift:init": "npx @pactflow/drift init",
    "drift:test-setup": "node test-drift-setup.js",
    "api:verify": "node simple-api-verify.js",
    "test:all": "npm run test:pact && npm run drift:verify"
  },
  "dependencies": {
    "@mdi/font": "7.0.96",
    "dotenv": "^16.4.7",
    "roboto-fontface": "*",
    "vue": "^3.2.0",
    "vue-router": "^4.0.0",
    "vuetify": "^3.0.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^15.0.1",
    "@pact-foundation/pact-cli": "^16.0.7",
    "@pactflow/drift": "^1.0.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "axios": "^1.8.3",
    "eslint": "^8.22.0",
    "eslint-plugin-vue": "^9.3.0",
    "jest": "^29.7.0",
    "unplugin-fonts": "^1.0.3",
    "vite": "^6.2.2",
    "vite-plugin-vuetify": "^2.1.0"
  }
}
